<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevLog - My Entries</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar">
        <span class="nav-brand">DevLog</span>
        <div class="nav-right">
            <span>
                <%= user.email %>
            </span>
            <form action="/auth/logout" method="POST" style="display:inline">
                <button type="submit" class="btn-logout">Logout</button>
            </form>
        </div>
    </nav>

    <div class="container">
        <div class="page-header">
            <h1>My Entries</h1>
            <a href="/entries/new" class="btn-primary">+ New Entry</a>
        </div>

        <% if (entries.length===0) { %>
            <div class="empty-state">
                <p>No entries yet.</p>
                <a href="/entries/new">Create your first entry</a>
            </div>
            <% } else { %>
                <div class="entries-list">
                    <% entries.forEach(entry=> { %>
                        <div class="entry-card">
                            <div class="entry-header">
                                <h3>
                                    <%= entry.title %>
                                </h3>
                                <span class="entry-date">
                                    <%= new Date(entry.createdAt).toLocaleDateString() %>
                                </span>
                            </div>

                            <p class="entry-body">
                                <%= entry.body %>
                            </p>

                            <div class="entry-footer">
                                <div class="tags">
                                    <% entry.tags.forEach(entryTag=> { %>
                                        <span class="tag">
                                            <%= entryTag.tag.name %>
                                        </span>
                                        <% }) %>
                                </div>

                                <form action="/entries/<%= entry.id %>?_method=DELETE" method="POST">
                                    <button type="submit" class="btn-delete">Delete</button>
                                </form>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } %>
    </div>
</body>

</html>